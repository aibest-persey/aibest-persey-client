# Mobile target (Capacitor): the app is packaged and runs with no dev-server
# proxy and no same-origin API, so it always needs an absolute URL.
#
# This placeholder must be pointed at your deployed aibest-persey-service
# instance before shipping a real build. For local device/emulator testing
# against a machine on your LAN, override it in a git-ignored .env.mobile.local
# instead of editing this file, e.g.:
#   VITE_API_URL=http://192.168.1.23:3000
VITE_API_URL=https://api.bellboard.example.com
